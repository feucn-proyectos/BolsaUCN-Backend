{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "System": "Warning"
      }
    },
    "WriteTo": [
      {
        "Name": "Console"
      },
      {
        "Name": "File",
        "Args": {
          "path": "logs/log-.txt",
          "rollingInterval": "Day",
          "retainedFileCountLimit": 14,
          "outputTemplate": "{Timestamp:yyyy-MM-dd HH:mm:ss.fff zzz} [{Level:u3}] {Message:lj}{NewLine}{Exception}"
        }
      }
    ],
    "Enrich": [
      "FromLogContext",
      "WithMachineName",
      "WithThreadId"
    ],
    "Properties": {
      "Application": "BolsaFeUcnApi"
    }
  },
  "ConnectionStrings": {
    "DefaultConnection": 
      "Server=localhost;Port=PUERTO;Database=NOMBRE_BASE_DATOS;Username=USUARIO;Password=CONTRASEÑA;"
  },
  "Cloudinary": {
    "CloudName": "",
    "ApiKey": "",
    "ApiSecret": ""
  },
  "Jwt":{
    "Key": ""
  },
  "ResendApiKey": "",
  "Testing": {
    "IsTesting": false,
    "IsCloudinaryOn": true,
    "FixedVerificationCode": "000000"
  },
  "Images": {
		"MaxBuySellImages": 3,
		"DefaultImageUrl": "/default-product.png",
    "DefaultImagePublicId": "default-product.svg",
		"DefaultUserImageUrl": "/default-user.svg",
		"DefaultUserImagePublicId": "default-user.svg",
		"DefaultPageSize": 10,
		"ImageAllowedExtensions": [
		".jpg",
		".jpeg",
		".png",
		".webp"
		],
		"ImageMaxSizeInBytes": 5242880,
		"TransformationWidth": 500,
		"TransformationCrop": "scale",
		"TransformationQuality": "35",
		"TransformationFetchFormat": "auto"
	},
	"Pagination": {
		"DefaultPageSize": 10,
		"MaxPageSize": 50
	},
  "AdminSettings": {
    "MaxAdminsAllowed": 3,
    "AllowedDomain": [
      "ucn.cl"
    ],
    "DefaultAdmin": {
      "Email": "",
      "Password": ""
    }
  },
  "StudentSettings": {
    "AllowedDomain": [
      "alumnos.ucn.cl"
    ]
  },
  "PublicationSettings": {
    "MaxAppeals": 3,
    "MaxPendingReviewsAllowed": 3,
    "AppealResponseTimeInHours": 48
  },
  "EmailConfiguration": {
    "From": "Bolsa Estudiantes UCN <onboarding@resend.dev>",
    "VerificationSubject": "Verificación de Correo Electrónico",
    "WelcomeSubject": "¡Bienvenido a Bolsa Estudiantes UCN!",
    "PasswordResetSubject": "Instrucciones para Reseteo de Contraseña"
  },
  "JobsConfiguration": {
    "DaysOfUnconfirmedUserRetention": 7,
    "DaysOfUnconfirmedPendingEmailChangeRetention": 3,
    "DaysUntilReviewAutoClose": 14
  },
  "AllowedHosts": "*",
  "AdminNotifications": {
    "Email": "admin@tu-dominio.com"
  },
  "Smtp": {
    "Host": "smtp.tu-dominio.com",
    "Port": 587,
    "EnableSsl": true,
    "User": "notificaciones@tu-dominio.com",
    "Password": "TU_PASSWORD_SUPER_SECRETA"
  }
}